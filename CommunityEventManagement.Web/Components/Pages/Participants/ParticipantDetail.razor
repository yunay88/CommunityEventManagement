@* FILE: CommunityEventManagement.Web/Components/Pages/Participants/ParticipantDetail.razor *@
@* REPLACE ENTIRE FILE – add Auth gating *@
@page "/participants/{Id:int}"
@using CommunityEventManagement.Web.Services
@inject IParticipantService ParticipantService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Participant Detail</PageTitle>

<LoadingSpinner IsLoading="@_loading" />

@if (!_loading && _p != null)
{
<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-0">@_p.FullName</h1>
        <small class="text-light opacity-75">@_p.Email</small>
    </div>
</div>

<div class="container pb-5">
    <div class="card shadow-sm">
        <div class="card-body">
            <p><strong>Email:</strong> @_p.Email</p>
            <p><strong>Phone:</strong> @(_p.PhoneNumber ?? "—")</p>
            <p><strong>Active Registrations:</strong> @_p.ActiveRegistrations</p>
            <p><strong>Joined:</strong> @_p.CreatedAt.ToString("dd MMM yyyy")</p>
            <div class="d-flex gap-2">
                <a href="/participants" class="btn btn-outline-secondary">Back</a>
                @if (AuthState.IsAdmin)
                {
                    <a href="/participants/edit/@Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                }
            </div>
        </div>
    </div>
</div>
}

@code {
    [Parameter] public int Id { get; set; }
    private ParticipantViewModel? _p;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var entity = await ParticipantService.GetParticipantWithRegistrationsAsync(Id);
        if (entity != null) _p = ParticipantViewModel.FromEntity(entity);
        _loading = false;
    }
}
