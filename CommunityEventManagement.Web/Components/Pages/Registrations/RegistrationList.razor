@page "/registrations"
@inject IRegistrationService RegistrationService

<PageTitle>Registrations</PageTitle>

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-0">
            <i class="bi bi-card-checklist"></i> All Registrations
        </h1>
    </div>
</div>

<div class="container pb-5">
    <AlertMessage Message="@_success" Type="success"
                  OnDismissed="@(() => _success = string.Empty)" />
    <AlertMessage Message="@_error" Type="danger"
                  OnDismissed="@(() => _error = string.Empty)" />

    <LoadingSpinner IsLoading="@_loading" />

    @if (!_loading)
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <span class="fw-semibold">
                    @_registrations.Count registration(s)
                </span>
            </div>
            <div class="card-body p-0">
                @if (!_registrations.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="bi bi-card-checklist display-3"></i>
                        <h5 class="mt-3">No registrations yet</h5>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Participant</th>
                                    <th>Event</th>
                                    <th>Event Date</th>
                                    <th>Registered</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _registrations)
                                {
                                    <tr>
                                        <td>@r.ParticipantName</td>
                                        <td>
                                            <a href="/events/@r.EventId">
                                                @r.EventName
                                            </a>
                                        </td>
                                        <td>
                                            @r.EventStartDate.ToString("dd/MM/yyyy")
                                        </td>
                                        <td>
                                            @r.RegistrationDate.ToString("dd/MM/yyyy")
                                        </td>
                                        <td>
                                            <span class="badge bg-@r.StatusColour">
                                                @r.StatusName
                                            </span>
                                        </td>
                                        <td>
                                            @if (r.Status !=
                                                Domain.Enums.RegistrationStatus.Cancelled)
                                            {
                                                <button class="btn btn-sm
                                                               btn-outline-danger"
                                                        @onclick="() => Cancel(r.Id)">
                                                    Cancel
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<RegistrationViewModel> _registrations = new();
    private bool _loading = true;
    private string _success = string.Empty;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            _loading = true;
            var all = await RegistrationService.GetAllRegistrationsAsync();
            _registrations = all.Select(RegistrationViewModel.FromEntity).ToList();
        }
        finally { _loading = false; }
    }

    private async Task Cancel(int id)
    {
        try
        {
            await RegistrationService.CancelRegistrationAsync(id, "Cancelled by admin");
            _success = "Registration cancelled.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}