@* FILE: CommunityEventManagement.Web/Components/Pages/Registrations/RegistrationList.razor *@
@* REPLACE ENTIRE FILE – adds "My Registrations" filter for Participants *@
@page "/registrations"
@page "/registrations/my"
@using CommunityEventManagement.Web.Services
@inject IRegistrationService RegistrationService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(AuthState.IsParticipant ? "My Registrations" : "Registrations")</PageTitle>

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="fw-bold mb-0">
                    <i class="bi bi-card-checklist"></i> 
                    @(AuthState.IsParticipant ? "My Registrations" : "All Registrations")
                </h1>
                @if (AuthState.IsAuthenticated)
                {
                    <small class="text-light opacity-75">@AuthState.CurrentUser.FullName</small>
                }
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <AlertMessage Message="@_success" Type="success"
                  OnDismissed="@(() => _success = string.Empty)" />
    <AlertMessage Message="@_error" Type="danger"
                  OnDismissed="@(() => _error = string.Empty)" />

    @if (!AuthState.IsAuthenticated)
    {
        <div class="alert alert-warning">
            Please <a href="/login">login</a> to view your registrations.
        </div>
    }
    else
    {

    <div class="card shadow-sm mb-3">
        <div class="card-body py-2 d-flex justify-content-between align-items-center">
            <div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="f_all"
                           name="filter" checked="@(_filterMine == false)"
                           @onchange="() => SetFilter(false)" 
                           disabled="@AuthState.IsParticipant" />
                    <label class="form-check-label" for="f_all">All</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="f_mine"
                           name="filter" checked="@_filterMine"
                           @onchange="() => SetFilter(true)" />
                    <label class="form-check-label" for="f_mine">My Registrations</label>
                </div>
            </div>
            <span class="text-muted small">@_registrations.Count registration(s)</span>
        </div>
    </div>

    <LoadingSpinner IsLoading="@_loading" />

    @if (!_loading)
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <span class="fw-semibold">
                    @_registrations.Count registration(s)
                </span>
            </div>
            <div class="card-body p-0">
                @if (!_registrations.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="bi bi-card-checklist display-3"></i>
                        <h5 class="mt-3">No registrations yet</h5>
                        <a href="/events" class="btn btn-primary mt-2">Browse Events</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Participant</th>
                                    <th>Event</th>
                                    <th>Event Date</th>
                                    <th>Registered</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _registrations)
                                {
                                    <tr>
                                        <td>@r.ParticipantName</td>
                                        <td>
                                            <a href="/events/@r.EventId">
                                                @r.EventName
                                            </a>
                                        </td>
                                        <td>
                                            @r.EventStartDate.ToString("dd/MM/yyyy")
                                        </td>
                                        <td>
                                            @r.RegistrationDate.ToString("dd/MM/yyyy")
                                        </td>
                                        <td>
                                            <span class="badge bg-@r.StatusColour">
                                                @r.StatusName
                                            </span>
                                        </td>
                                        <td>
                                            @if (r.Status != Domain.Enums.RegistrationStatus.Cancelled 
                                                && CanCancel(r))
                                            {
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => Cancel(r.Id)">
                                                    Cancel
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
    }
</div>

@code {
    private List<RegistrationViewModel> _registrations = new();
    private bool _loading = true;
    private string _success = string.Empty;
    private string _error = string.Empty;
    private bool _filterMine = false;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        // Participants default to "my registrations" only
        if (AuthState.IsAuthenticated && AuthState.IsParticipant)
            _filterMine = true;
        await Load();
    }

    private async void AuthChanged() => await InvokeAsync(async () => await Load());

    private async Task SetFilter(bool mine)
    {
        _filterMine = mine;
        await Load();
    }

    private bool CanCancel(RegistrationViewModel r)
    {
        if (AuthState.IsAdmin) return true;
        // Participant can only cancel their own
        return AuthState.IsAuthenticated && 
               string.Equals(r.ParticipantEmail, AuthState.CurrentUser.Email, StringComparison.OrdinalIgnoreCase);
    }

    private async Task Load()
    {
        try
        {
            _loading = true;
            if (!AuthState.IsAuthenticated)
            {
                _registrations = new();
                return;
            }

            IEnumerable<CommunityEventManagement.Domain.Entities.Registration> all;

            if (_filterMine && AuthState.UserId.HasValue)
            {
                all = await RegistrationService.GetRegistrationsByParticipantAsync(AuthState.UserId.Value);
            }
            else if (AuthState.IsParticipant && AuthState.UserId.HasValue)
            {
                // Force participant-only view
                all = await RegistrationService.GetRegistrationsByParticipantAsync(AuthState.UserId.Value);
                _filterMine = true;
            }
            else
            {
                // Admin sees all
                all = await RegistrationService.GetAllRegistrationsAsync();
            }

            _registrations = all.Select(RegistrationViewModel.FromEntity).ToList();
        }
        finally { _loading = false; }
    }

    private async Task Cancel(int id)
    {
        try
        {
            var reason = AuthState.IsAdmin ? "Cancelled by admin" : "Cancelled by participant";
            await RegistrationService.CancelRegistrationAsync(id, reason);
            _success = "Registration cancelled.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    public void Dispose() => AuthState.OnAuthStateChanged -= AuthChanged;
}
