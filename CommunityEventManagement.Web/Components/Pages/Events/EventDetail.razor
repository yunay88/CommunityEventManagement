@* FILE: CommunityEventManagement.Web/Components/Pages/Events/EventDetail.razor *@
@* FIXED VERSION – uses EventDetailViewModel which has Registrations + Activities *@
@page "/events/{Id:int}"
@using CommunityEventManagement.Web.Services
@inject IEventService EventService
@inject IRegistrationService RegistrationService
@inject IParticipantService ParticipantService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(_event?.Name ?? "Event Detail")</PageTitle>

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading && _event != null)
{
    <div class="page-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1">
                            <li class="breadcrumb-item">
                                <a href="/events" class="text-light">Events</a>
                            </li>
                            <li class="breadcrumb-item active text-white">
                                @_event.Name
                            </li>
                        </ol>
                    </nav>
                    <h1 class="fw-bold mb-0">@_event.Name</h1>
                    <span class="badge bg-@_event.StatusColour mt-2">
                        @_event.StatusBadge
                    </span>
                </div>
                <div class="col-auto d-flex gap-2">
                    @if (AuthState.IsAdmin)
                    {
                        <a href="/events/edit/@_event.Id"
                           class="btn btn-outline-light">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    }
                    <a href="/events"
                       class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container pb-5">

        <AlertMessage Message="@_successMessage" Type="success"
                      OnDismissed="@(() => _successMessage = string.Empty)" />
        <AlertMessage Message="@_errorMessage" Type="danger"
                      OnDismissed="@(() => _errorMessage = string.Empty)" />

        <div class="row g-4">

            <!-- Event Details -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-info-circle text-primary"></i>
                        Event Details
                    </div>
                    <div class="card-body">
                        <p class="text-muted">@_event.Description</p>
                        <hr />
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-calendar3 text-primary fs-5"></i>
                                    <div>
                                        <div class="small text-muted">Start</div>
                                        <strong>
                                            @_event.StartDate.ToString(
                                                "ddd dd MMM yyyy, HH:mm")
                                        </strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-calendar3-range
                                              text-danger fs-5"></i>
                                    <div>
                                        <div class="small text-muted">End</div>
                                        <strong>
                                            @_event.EndDate.ToString(
                                                "ddd dd MMM yyyy, HH:mm")
                                        </strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-clock text-warning fs-5"></i>
                                    <div>
                                        <div class="small text-muted">Duration</div>
                                        <strong>@_event.DurationFormatted</strong>
                                    </div>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(_event.VenueName))
                            {
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-geo-alt
                                                  text-danger fs-5"></i>
                                        <div>
                                            <div class="small text-muted">
                                                Venue
                                            </div>
                                            <strong>@_event.VenueName</strong>
                                            <div class="small text-muted">
                                                @_event.VenueLocation
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Activities -->
                @if (_event.Activities.Any())
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white fw-bold">
                            <i class="bi bi-lightning text-warning"></i>
                            Activities (@_event.Activities.Count)
                        </div>
                        <div class="card-body">
                            <div class="row g-2">
                                @foreach (var activity in _event.Activities)
                                {
                                    <div class="col-md-6">
                                        <div class="border rounded p-2 d-flex
                                                    align-items-center gap-2">
                                            <span class="badge bg-primary">
                                                @activity.TypeName
                                            </span>
                                            <span>@activity.Name</span>
                                            <small class="text-muted ms-auto">
                                                @activity.DurationFormatted
                                            </small>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Registrations (Admin only) -->
                @if (AuthState.IsAdmin)
                {
                <div class="card shadow-sm">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-people text-success"></i>
                        Registered Participants (@_event.Registrations.Count)
                    </div>
                    <div class="card-body p-0">
                        @if (!_event.Registrations.Any())
                        {
                            <div class="p-4 text-center text-muted">
                                No registrations yet.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Participant</th>
                                            <th>Email</th>
                                            <th>Registered</th>
                                            <th>Status</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var reg in _event.Registrations)
                                        {
                                            <tr>
                                                <td>@reg.ParticipantName</td>
                                                <td>@reg.ParticipantEmail</td>
                                                <td>
                                                    @reg.RegistrationDate.ToString(
                                                        "dd/MM/yyyy")
                                                </td>
                                                <td>
                                                    <span class="badge bg-@reg.StatusColour">
                                                        @reg.StatusName
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (reg.Status != CommunityEventManagement.Domain.Enums.RegistrationStatus.Cancelled)
                                                    {
                                                        <button class="btn btn-sm
                                                                       btn-outline-danger"
                                                                @onclick="() => CancelRegistration(reg.Id)">
                                                            Cancel
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
                }
            </div>

            <!-- Sidebar: Register -->
            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 1rem;">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="bi bi-ticket-perforated"></i>
                        Register for this Event
                    </div>
                    <div class="card-body">
                        @if (!AuthState.IsAuthenticated)
                        {
                            <p class="text-muted small">Please log in to register.</p>
                            <a href="/login?returnUrl=/events/@Id" class="btn btn-primary w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Login to Register
                            </a>
                        }
                        else if (AuthState.IsAdmin)
                        {
                            <p class="text-muted small">Admins manage registrations in the table opposite.</p>
                            <div class="alert alert-info small py-2">
                                Logged in as Admin: @AuthState.CurrentUser.FullName
                            </div>
                        }
                        else
                        {
                            @if (_isRegistered)
                            {
                                <div class="alert alert-success">
                                    <i class="bi bi-check-circle-fill"></i>
                                    You are registered for this event!
                                </div>
                                <button class="btn btn-outline-danger w-100"
                                        @onclick="CancelMyRegistration"
                                        disabled="@_isRegistering">
                                    Cancel My Registration
                                </button>
                            }
                            else
                            {
                                <p class="small text-muted mb-2">
                                    Registering as:<br />
                                    <strong>@AuthState.CurrentUser.FullName</strong><br />
                                    @AuthState.CurrentUser.Email
                                </p>
                                <button class="btn btn-success w-100"
                                        @onclick="RegisterMe"
                                        disabled="@_isRegistering">
                                    @if (_isRegistering)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-ticket-perforated"></i>
                                    Register Now
                                </button>
                            }
                        }
                        <hr />
                        <div class="small text-muted">
                            <i class="bi bi-people"></i>
                            @_event.ParticipantCount participant(s) registered
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private EventDetailViewModel? _event;
    private bool _isLoading = true;
    private bool _isRegistering = false;
    private string _successMessage = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isRegistered = false;
    private int? _myRegistrationId;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += AuthChanged;
        await LoadAsync();
    }

    private async void AuthChanged() => await InvokeAsync(async () => await LoadAsync());

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            var entity = await EventService.GetEventWithDetailsAsync(Id);
            if (entity != null)
            {
                _event = EventDetailViewModel.FromEntity(entity);
                await CheckMyRegistrationAsync();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CheckMyRegistrationAsync()
    {
        _isRegistered = false;
        _myRegistrationId = null;
        if (AuthState.IsAuthenticated && AuthState.UserId.HasValue && _event != null)
        {
            var myReg = _event.Registrations.FirstOrDefault(r => 
                string.Equals(r.ParticipantEmail, AuthState.CurrentUser.Email, StringComparison.OrdinalIgnoreCase));
            if (myReg != null)
            {
                _isRegistered = true;
                _myRegistrationId = myReg.Id;
            }
        }
        await Task.CompletedTask;
    }

    private async Task RegisterMe()
    {
        if (!AuthState.IsAuthenticated || !AuthState.UserId.HasValue)
        {
            Navigation.NavigateTo($"/login?returnUrl=/events/{Id}");
            return;
        }
        try
        {
            _isRegistering = true;
            _errorMessage = string.Empty;
            var reg = await RegistrationService.RegisterParticipantAsync(AuthState.UserId.Value, Id);
            _successMessage = "Successfully registered for this event!";
            await LoadAsync();
        }
        catch (CommunityEventManagement.Domain.Exceptions.DuplicateRegistrationException ex)
        {
            _errorMessage = ex.Message;
            await CheckMyRegistrationAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isRegistering = false;
        }
    }

    private async Task CancelMyRegistration()
    {
        if (!_myRegistrationId.HasValue) return;
        try
        {
            _isRegistering = true;
            await RegistrationService.CancelRegistrationAsync(_myRegistrationId.Value, "Cancelled by participant");
            _successMessage = "Your registration has been cancelled.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally { _isRegistering = false; }
    }

    private async Task CancelRegistration(int registrationId)
    {
        if (!AuthState.IsAdmin) { _errorMessage = "Admin access required."; return; }
        try
        {
            await RegistrationService.CancelRegistrationAsync(registrationId, "Cancelled by admin");
            _successMessage = "Registration cancelled.";
            await LoadAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= AuthChanged;
    }
}
