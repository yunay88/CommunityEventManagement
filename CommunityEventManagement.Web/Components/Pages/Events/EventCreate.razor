@page "/events/create"
@inject IEventService EventService
@inject IVenueService VenueService
@inject IActivityService ActivityService
@inject NavigationManager Navigation

<PageTitle>Create Event</PageTitle>

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-0">
            <i class="bi bi-plus-circle"></i> Create New Event
        </h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <AlertMessage Message="@_errorMessage" Type="danger"
                                  OnDismissed="@(() => _errorMessage = string.Empty)" />

                    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-warning" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Event Name <span class="text-danger">*</span>
                            </label>
                            <InputText @bind-Value="_model.Name"
                                       class="form-control"
                                       placeholder="Enter event name" />
                            <ValidationMessage For="@(() => _model.Name)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Description
                            </label>
                            <InputTextArea @bind-Value="_model.Description"
                                           class="form-control" rows="3"
                                           placeholder="Describe your event..." />
                            <ValidationMessage For="@(() => _model.Description)"
                                               class="text-danger small" />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Start Date & Time <span class="text-danger">*</span>
                                </label>
                                <InputDate Type="InputDateType.DateTimeLocal"
                                           @bind-Value="_model.StartDate"
                                           class="form-control" />
                                <ValidationMessage For="@(() => _model.StartDate)"
                                                   class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    End Date & Time <span class="text-danger">*</span>
                                </label>
                                <InputDate Type="InputDateType.DateTimeLocal"
                                           @bind-Value="_model.EndDate"
                                           class="form-control" />
                                <ValidationMessage For="@(() => _model.EndDate)"
                                                   class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Venue</label>
                            <InputSelect @bind-Value="_model.VenueId"
                                         class="form-select">
                                <option value="">-- No Venue Selected --</option>
                                @foreach (var venue in _venues)
                                {
                                    <option value="@venue.Id">
                                        @venue.Name — @venue.City
                                        (Capacity: @venue.MaxCapacity)
                                    </option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Activities</label>
                            <div class="border rounded p-3"
                                 style="max-height:200px; overflow-y:auto;">
                                @foreach (var activity in _activities)
                                {
                                    <div class="form-check">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               id="act_@activity.Id"
                                               checked="@_model.SelectedActivityIds
                                                        .Contains(activity.Id)"
                                               @onchange="e => ToggleActivity(
                                                   activity.Id,
                                                   (bool)e.Value!)" />
                                        <label class="form-check-label"
                                               for="act_@activity.Id">
                                            @activity.Name
                                            <span class="badge bg-light
                                                         text-dark ms-1">
                                                @activity.TypeName
                                            </span>
                                            <small class="text-muted">
                                                (@activity.DurationFormatted)
                                            </small>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary"
                                    disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border
                                                 spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-circle"></i> Create Event
                            </button>
                            <a href="/events"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateEventModel _model = new();
    private List<VenueViewModel> _venues = new();
    private List<ActivityViewModel> _activities = new();
    private bool _isSubmitting = false;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var venues = await VenueService.GetAllVenuesAsync();
            _venues = venues.Select(VenueViewModel.FromEntity).ToList();

            var activities = await ActivityService.GetAllActivitiesAsync();
            _activities = activities.Select(ActivityViewModel.FromEntity).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading form data: {ex.Message}";
        }
    }

    private void ToggleActivity(int activityId, bool isChecked)
    {
        if (isChecked && !_model.SelectedActivityIds.Contains(activityId))
            _model.SelectedActivityIds.Add(activityId);
        else if (!isChecked)
            _model.SelectedActivityIds.Remove(activityId);
    }

    private async Task HandleSubmit()
    {
        try
        {
            _isSubmitting = true;
            _errorMessage = string.Empty;

            var createdEvent = await EventService.CreateEventAsync(
                _model.Name,
                _model.Description,
                _model.StartDate,
                _model.EndDate,
                _model.VenueId);

            Navigation.NavigateTo($"/events/{createdEvent.Id}");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}